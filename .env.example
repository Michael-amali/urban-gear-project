# Storage backend: local | local-s3 | prod
#   local     → ./data filesystem
#   local-s3  → MinIO Play (S3-compatible)
#   prod      → AWS S3
ENV=local

# Used by local-s3 / prod
S3_BUCKET=urbangear-data-lake-myk
S3_ENDPOINT_URL=https://play.min.io
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Used by ENV=local
LOCAL_DATA_PATH=./data

PYTHON_PATH_311=C:\Users\{user name}\AppData\Local\Programs\Python\Python311\python.exe

# Warehouse Database
WAREHOUSE_DB=
WAREHOUSE_USER=
WAREHOUSE_PASSWORD=

# Airflow Metadata Database
AIRFLOW_DB=
AIRFLOW_USER=
AIRFLOW_PASSWORD=

# Airflow Admin User
AIRFLOW_ADMIN_USERNAME=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

AIRFLOW_SECRET_KEY=

AWS_CONN_ID=
